rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Whitelist collection: Only readable by authenticated users (to check if they are in it?
    // Actually, usually admin SDK manages this, but frontend might need to check self).
    // For now, let's keep it restrictive and refine in the backend step.
    match /whitelist/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
    }

    // Audit logs: Only writable by backend (Admin SDK bypasses rules), readable by whitelisted users.
    match /audit_logs/{log} {
       allow read: if request.auth != null &&
         exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email));
    }
  }
}
